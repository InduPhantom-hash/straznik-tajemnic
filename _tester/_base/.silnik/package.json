{
  "name": "straznik-tajemnic",
  "version": "4.0.0-local",
  "private": true,
  "scripts": {
    "dev": "NODE_OPTIONS='--max-old-space-size=4096' next dev --webpack --port ${PORT:-3000}",
    "build": "next build --webpack",
    "start": "NODE_OPTIONS='--max-old-space-size=4096' next start --port ${PORT:-3000}",
    "cold-start": "bash desktop/cold-start.sh",
    "lint": "eslint",
    "format": "prettier --write .",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "rag:reindex": "node --experimental-strip-types scripts/reindex-pdfs.ts",
    "rag:index-mythos": "node --experimental-strip-types scripts/index-cthulhu-wiki.ts",
    "rag:convert-binary": "node --experimental-strip-types scripts/convert-rag-binary.ts",
    "backup": "node backup.mjs create",
    "backup:auto": "node backup.mjs auto",
    "backup:list": "node backup.mjs list",
    "backup:restore": "node backup.mjs restore",
    "backup:clean": "node backup.mjs clean",
    "qa": "node qa-runner.mjs",
    "qa:quick": "node qa-runner.mjs --quick",
    "qa:diagnose": "node qa-diagnose.mjs",
    "qa:e2e": "npx playwright test tests/e2e/full-qa.spec.ts --project=chromium",
    "qa:e2e:all": "npx playwright test tests/e2e/full-qa.spec.ts",
    "qa:full": "node qa-runner.mjs && npx playwright test tests/e2e/full-qa.spec.ts --project=chromium",
    "playtest": "npx playwright test tests/e2e/full-playtest.spec.ts --project=chromium --timeout=2400000",
    "playtest:headed": "npx playwright test tests/e2e/full-playtest.spec.ts --project=chromium --timeout=2400000 --headed",
    "playtest:quick": "npx playwright test tests/e2e/full-playtest.spec.ts --project=chromium --timeout=600000",
    "smoke:secrets": "node --experimental-strip-types scripts/smoke-all-secrets.ts",
    "prepare": "node scripts/gen-adventure-catalog.mjs && (husky || true)",
    "gen:catalog": "node scripts/gen-adventure-catalog.mjs",
    "predev": "node scripts/gen-adventure-catalog.mjs",
    "prebuild": "node scripts/gen-adventure-catalog.mjs"
  },
  "dependencies": {
    "@google-cloud/storage": "^7.17.1",
    "@google-cloud/vertexai": "^1.10.0",
    "@google/genai": "^1.50.1",
    "@google/generative-ai": "^0.24.1",
    "@next/bundle-analyzer": "^16.2.4",
    "@pinecone-database/pinecone": "^7.1.0",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-aspect-ratio": "^1.1.7",
    "@radix-ui/react-avatar": "^1.1.10",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-hover-card": "^1.1.15",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-menubar": "^1.1.16",
    "@radix-ui/react-navigation-menu": "^1.2.14",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.7",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toast": "^1.2.15",
    "@radix-ui/react-toggle": "^1.1.10",
    "@radix-ui/react-toggle-group": "^1.1.11",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@sentry/nextjs": "^10.51.0",
    "@testing-library/dom": "^10.4.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "fast-deep-equal": "^3.1.3",
    "file-type": "^21.1.1",
    "geist": "^1.4.2",
    "html2canvas": "^1.4.1",
    "lucide-react": "^0.542.0",
    "next": "^16.2.4",
    "pdf-parse": "^1.1.1",
    "posthog-js": "^1.365.0",
    "react": "^19.2.5",
    "react-day-picker": "^9.10.0",
    "react-dom": "^19.2.5",
    "tailwind-merge": "^3.3.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@playwright/test": "^1.57.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^20",
    "@types/pdf-parse": "^1.1.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/parser": "^8.41.0",
    "autoprefixer": "^10.4.21",
    "eslint": "^9",
    "eslint-config-next": "15.5.2",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.6.2",
    "tailwindcss": "^3.4.3",
    "ts-jest": "^29.4.9",
    "typescript": "^5"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix --max-warnings=20",
      "prettier --write",
      "jest --bail --findRelatedTests --passWithNoTests"
    ],
    "*.mjs": [
      "eslint --fix --max-warnings=20",
      "prettier --write"
    ],
    "*.js": [
      "eslint --fix --max-warnings=20",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "overrides": {
    "js-cookie": "^3.0.7",
    "uuid": "^11.1.1",
    "postcss": "^8.5.10"
  }
}
