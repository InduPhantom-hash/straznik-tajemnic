# ==========================================================================
#  Strażnik Tajemnic AI - konfiguracja środowiska
#  Skopiuj ten plik do `.env.local` i uzupełnij. `.env.local` jest w .gitignore.
# ==========================================================================

# --------------------------------------------------------------------------
#  WYMAGANE
# --------------------------------------------------------------------------
# Klucz Google AI Studio (rodzina Gemini API). Obsługuje WSZYSTKO czego apka
# potrzebuje na starcie: czat (Mistrz Gry), embeddingi RAG, lektor (TTS) oraz
# generowanie obrazów. To jedyny wymagany klucz.
#   Skąd wziąć: https://aistudio.google.com/apikey  (darmowy tier wystarcza na start)
GEMINI_API_KEY=

# --------------------------------------------------------------------------
#  OPCJONALNE - lepsze obrazy / alternatywny lektor
#  Wszystko poniżej można pominąć. Bez tych kluczy apka działa na samym Gemini.
# --------------------------------------------------------------------------
# Alternatywny generator obrazów (Replicate Flux). Tańszy fallback.
#   Skąd: https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=

# Wyższa jakość obrazów (Google Vertex AI Imagen 4). Wymaga projektu GCP.
#   Skąd: https://console.cloud.google.com  (Vertex AI -> klucz API + projekt)
VERTEX_AI_API_KEY=
VERTEX_AI_PROJECT_ID=

# Alternatywny lektor (Google Cloud Text-to-Speech: Wavenet / Chirp3-HD).
#   Skąd: https://console.cloud.google.com  (Cloud Text-to-Speech API)
GOOGLE_CLOUD_API_KEY=

# --------------------------------------------------------------------------
#  ZAAWANSOWANE / DEWELOPERSKIE (zostaw puste przy normalnym użyciu)
# --------------------------------------------------------------------------
# Tryb lokalny - pomija modal "wklej klucz" i czyta klucz z env (dla buildów
# z wgranym kluczem). Wersja publiczna: zostaw `false` (gracz wkleja swój klucz w UI).
NEXT_PUBLIC_LOCAL_MODE=false

# Katalog lokalnego indeksu RAG (domyślnie `data/rag/`). Zostaw puste.
# RAG_DATA_DIR=
# ZEW_DATA_DIR=

# Wersja schematu embeddingów RAG. Skrypt indeksujący i aplikacja MUSZĄ mieć tę
# samą wartość (inaczej wyszukiwanie zwraca 0 wyników). Zostaw domyślne.
# RAG_VERSION=v2

# Anonimowa telemetria PostHog - domyślnie WYŁĄCZONA (brak klucza = brak zbierania).
# NEXT_PUBLIC_POSTHOG_KEY=
# NEXT_PUBLIC_POSTHOG_HOST=
